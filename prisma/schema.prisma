generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   // admin, doctor, nurse
  name      String
  createdAt DateTime @default(now())
}

model Patient {
  id            Int            @id @default(autoincrement())
  historyNumber String         @unique
  firstName     String
  lastName      String
  personalId    String         @unique
  birthDate     String?
  gender        String?
  phone         String?
  address       String?
  prescriptions Prescription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Prescription {
  id            Int      @id @default(autoincrement())
  type          String   // stationary, stationary24, home
  data          String   // JSON stringified form data
  patientId     Int
  patient       Patient  @relation(fields: [patientId], references: [id])
  createdBy     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // stationary, stationary24, home
  data      String   // JSON stringified form data
  createdBy Int
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())
}
